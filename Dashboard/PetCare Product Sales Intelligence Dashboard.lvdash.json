{
  "datasets": [
    {
      "name": "5c89c146",
      "displayName": "KPI_Total_Revenue",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT \n",
        "  ROUND(SUM(total_revenue), 2) AS total_revenue\n",
        "FROM workspace.default.gold_product_performance;"
      ]
    },
    {
      "name": "8a57448b",
      "displayName": "KPI_Total_Sales",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT \n",
        "  SUM(total_sales) AS total_sales\n",
        "FROM workspace.default.gold_product_performance;"
      ]
    },
    {
      "name": "2d1ec1c0",
      "displayName": "Product_Category_Revenue",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT \n",
        "  product_category,\n",
        "  total_revenue\n",
        "FROM workspace.default.gold_product_performance\n",
        "ORDER BY total_revenue DESC;"
      ]
    },
    {
      "name": "4c348dca",
      "displayName": "Top_20_Vendor_Performance",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT \n",
        "  vendor_id,\n",
        "  vendor_revenue,\n",
        "  average_rating,\n",
        "  products_supplied\n",
        "FROM workspace.default.gold_vendor_performance\n",
        "ORDER BY vendor_revenue DESC\n",
        "LIMIT 20;"
      ]
    },
    {
      "name": "422d7f7f",
      "displayName": "Country_Sales_Performance",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT \n",
        "  country,\n",
        "  country_revenue,\n",
        "  total_units_sold\n",
        "FROM workspace.default.gold_country_sales\n",
        "ORDER BY country_revenue DESC;"
      ]
    },
    {
      "name": "78a3dbe8",
      "displayName": "Rebuy_Analysis",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT \n",
        "  CASE \n",
        "    WHEN re_buy = 1 THEN 'Re-buy'\n",
        "    ELSE 'No Re-buy'\n",
        "  END AS rebuy_status,\n",
        "  revenue,\n",
        "  transactions,\n",
        "  average_rating\n",
        "FROM workspace.default.gold_rebuy;"
      ]
    },
    {
      "name": "b70932db",
      "displayName": "Pet_Type_Revenue",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT \n",
        "  pet_type,\n",
        "  revenue,\n",
        "  average_rating,\n",
        "  products\n",
        "FROM workspace.default.gold_pet_type\n",
        "ORDER BY revenue DESC;"
      ]
    }
  ],
